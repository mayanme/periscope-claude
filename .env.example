# Database — Supabase PostgreSQL (Transaction pooler URL)
# Get from: Supabase Dashboard → Settings → Database → Connection string → Transaction pooler
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# Direct connection URL for Prisma migrations (Session pooler or direct)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Supabase (used for file storage on Vercel)
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# AI APIs
ANTHROPIC_API_KEY="sk-ant-..."
EXA_API_KEY="exa-..."

# Inngest (leave blank for local dev — only needed for Vercel)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# File storage — use "local" for dev, "vercel" for production
STORAGE_MODE="local"
UPLOAD_DIR="./uploads"

# Queue mode:
# "local"  — fire-and-forget (no extra process, works on persistent servers)
# "inngest" — Inngest background jobs (required for Vercel serverless)
QUEUE_MODE="local"
